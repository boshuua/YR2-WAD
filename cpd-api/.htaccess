# Backend API .htaccess
# Prevent directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.(env|git|gitignore|vendor)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Allow access to PHP files
<FilesMatch "\.php$">
  Order allow,deny
  Allow from all
</FilesMatch>

# Route API requests to Front Controller
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_URI} ^/api/.*\.php$ [NC]
  RewriteCond %{REQUEST_URI} !^/api/index\.php$ [NC]
  RewriteRule ^api/(.*\.php)$ api/index.php [L,QSA]
</IfModule>

# Set default charset
AddDefaultCharset utf-8

# Security Headers
<IfModule mod_headers.c>
  # Prevent clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"
  
  # Enable XSS protection
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  
  # HSTS - Force HTTPS (6 months)
  Header always set Strict-Transport-Security "max-age=15768000; includeSubDomains"
  
  # Referrer Policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Enable Gzip compression for API responses
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
</IfModule>