# Turn on the URL rewriting engine
RewriteEngine On

# Ensure the following rules are not applied to existing files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# --- URL Rewriting Rules ---

# Login Page
RewriteRule ^login/?$ /login.php [L]

# User Pages
RewriteRule ^dashboard/?$ /user/dashboard.php [L]
RewriteRule ^courses/?$ /user/courses.php [L]
RewriteRule ^profile/?$ /user/profile.php [L]
RewriteRule ^my-courses/?$ /user/my_courses.php [L]
RewriteRule ^course/([0-9]+)/?$ /user/course_details.php?id=$1 [L]

# Admin Pages
RewriteRule ^admin/dashboard/?$ /admin/dashboard.php [L]
RewriteRule ^admin/users/?$ /admin/users.php [L]
RewriteRule ^admin/courses/?$ /admin/courses.php [L]
RewriteRule ^admin/logs/?$ /admin/view_log.php [L]

# --- Error and Cache Rules ---
ErrorDocument 404 /404_handler.php

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
</IfModule>